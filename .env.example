# ═══════════════════════════════════════════════════════════════
# JuriThèque — Variables d'environnement (FRONTEND)
# Copier ce fichier en .env et remplir les valeurs
# ⚠️  Ne jamais committer .env sur Git
# ═══════════════════════════════════════════════════════════════

# Supabase — clé PUBLIQUE (safe à partager, protégée par RLS)
VITE_SUPABASE_URL=https://[votre-projet].supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_[...]

# OpenRouter — pour l'assistant IA (page /assistant)
# Obtenir sur : https://openrouter.ai/keys
VITE_OPENROUTER_KEY=sk-or-v1-[...]
