# ═══════════════════════════════════════════════════════════════
# JuriThèque — Variables d'environnement (PIPELINE PYTHON)
# Copier ce fichier en .env et remplir les valeurs
# ⚠️  JAMAIS committer pipeline/.env sur Git
# ⚠️  SUPABASE_SERVICE_KEY = droits admin complets sur la BDD
# ═══════════════════════════════════════════════════════════════

# Supabase — URL du projet
SUPABASE_URL=https://[votre-projet].supabase.co

# Supabase — clé SERVICE_ROLE (SECRÈTE — accès administrateur total)
# Obtenir dans Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_KEY=sb_secret_[...]

# OpenRouter — pour les scripts IA (génération + traduction)
# Obtenir sur : https://openrouter.ai/keys
# Modèle utilisé : google/gemini-2.5-flash-lite
OPENROUTER_KEY=sk-or-v1-[...]
