{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://juritheque.local/schemas/consistency_audit_result.schema.json",
  "title": "ConsistencyAuditResult",
  "type": "object",
  "required": [
    "law_id",
    "score",
    "decision",
    "flags",
    "blocking",
    "auto_update_allowed"
  ],
  "properties": {
    "law_id": {
      "type": ["integer", "string"]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "decision": {
      "type": "string",
      "enum": [
        "auto_update",
        "review",
        "review_high_priority",
        "block",
        "no_change"
      ]
    },
    "flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warning", "critical", "blocking"]
          },
          "message": {
            "type": "string"
          },
          "field": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    },
    "blocking": {
      "type": "boolean"
    },
    "auto_update_allowed": {
      "type": "boolean"
    },
    "recommended_patch": {
      "type": ["object", "null"]
    },
    "review_reason": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}

